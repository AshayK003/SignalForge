# LLM Provider: "openrouter", "ollama", "deepseek", or use Gemini bot
LLM_PROVIDER=ollama

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# DeepSeek direct
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat

# Ollama (local, unlimited)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Gemini API (free tier — for Telegram bot)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Telegram Bot (for bot.py)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# External dependency paths (optional — omit to skip)
# Point these to your installs of Deno, FFmpeg, Tesseract, Poppler
# SIGNALFORGE_DENO_PATH=
# SIGNALFORGE_FFMPEG_PATH=
# SIGNALFORGE_TESSERACT_CMD=
# SIGNALFORGE_POPPLER_BIN=

# Rclone
RCLONE_REMOTE=mega
RCLONE_PATH=SignalForge
